APP_NAME="Golden Bird CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — local + Railway/Render free tier)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL (VPS / DigitalOcean / local MySQL)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=golden_bird_crm
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (Render managed DB / Supabase)
# DB_CONNECTION=pgsql
# DB_HOST=dpg-xxxxx.oregon-postgres.render.com
# DB_PORT=5432
# DB_DATABASE=golden_bird_crm
# DB_USERNAME=golden_bird_crm_user
# DB_PASSWORD=

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=local

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@goldenbird.co.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_DRIVER=log

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ── Railway (auto-injected by Railway, uncomment if needed locally) ───────────
# DATABASE_URL=
# PORT=8000

# ── Vercel (Vercel Edge requires external DB — uncomment & fill) ──────────────
# VERCEL=1
# DB_CONNECTION=pgsql
# DB_URL=postgres://user:pass@host:5432/dbname

# ── Render (Render injects DATABASE_URL automatically for managed DBs) ────────
# DATABASE_URL=

# ── Performance (production) ─────────────────────────────────────────────────
# OPCACHE_ENABLE=1
# PHP_MEMORY_LIMIT=256M
